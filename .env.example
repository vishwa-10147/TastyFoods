# App runtime
NODE_ENV=production
PORT=10000

DATABASE_URL=your_postgres_connection_string
# Set to true for Supabase/Neon/Render external URLs if TLS is required.
# Leave empty for Render internal database URLs in the same account and region.
PGSSL=true

# When using a managed PostgreSQL instance, require a persistent database connection.
# This value does not change runtime behavior for local development, but documents the deployment intent.
REQUIRE_PERSISTENT_DB=true

# Razorpay (optional for online UPI/Card)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Basic API rate limiting (in-memory)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=240

# Optional: open a restaurant directly from the root domain.
# When set, this restaurant code will be used when visiting the root domain
# Example: PUBLIC_DEFAULT_RESTAURANT_CODE=gandikotadosa
# This would make: https://example.com/#order show gandikotadosa restaurant
PUBLIC_DEFAULT_RESTAURANT_CODE=

# Optional: map multiple custom domains to restaurant codes.
# Format: domain1:restaurantCode1,domain2:restaurantCode2
# This maps specific domain names to specific restaurant codes
# 
# For gandikotadosa.in, you have 2 options:
# 
# OPTION 1: Using RESTAURANT_DOMAIN_MAP (specific per domain)
# Maps both gandikotadosa.in and www.gandikotadosa.in to gandikotadosa restaurant
# RESTAURANT_DOMAIN_MAP=gandikotadosa.in:gandikotadosa,www.gandikotadosa.in:gandikotadosa
# 
# OPTION 2: Using PUBLIC_DEFAULT_RESTAURANT_CODE (simpler, for main domain)
# Makes gandikotadosa the default for your main domain
# PUBLIC_DEFAULT_RESTAURANT_CODE=gandikotadosa
# 
# Multiple restaurants example:
# RESTAURANT_DOMAIN_MAP=gandikotadosa.in:gandikotadosa,www.gandikotadosa.in:gandikotadosa,otherrestaurant.in:otherrestaurant
RESTAURANT_DOMAIN_MAP=

# Management authentication
# Used to sign login tokens (set a long random value in production)
MANAGEMENT_AUTH_SECRET=
# Optional one-time default password for the default restaurant account
MANAGEMENT_DEFAULT_PASSWORD=
# Fallback used when no auth row exists and MANAGEMENT_DEFAULT_PASSWORD is empty
MANAGEMENT_DEV_FALLBACK_PASSWORD=admin123
# Required to add/update restaurant management passwords after first bootstrap account
MANAGEMENT_SETUP_KEY=

# WhatsApp Business API Integration (optional)
# Enable to send order notifications via WhatsApp
# Get these from: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started

# WhatsApp Cloud API Access Token
# Create a business app at https://developers.facebook.com
# Generate a system user access token with whatsapp_business_messaging permission
WHATSAPP_ACCESS_TOKEN=

# Phone Number ID
# The ID of the phone number associated with your WhatsApp Business Account
# Found in WhatsApp Manager > Phone Numbers > [Your Number] > Phone Number ID
WHATSAPP_PHONE_NUMBER_ID=

# Webhook Verification Token
# Create any random string (min 16 chars recommended)
# Must be set in WhatsApp Manager > Phone Numbers > Webhook > Verify Token
WHATSAPP_VERIFY_TOKEN=

# Test phone number for WhatsApp testing (optional)
# Use for testing: npm run whatsapp-test
# Format: 10-digit number or include country code (e.g., 919010002233)
TEST_PHONE_NUMBER=
